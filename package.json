{
	"name": "my-better-t-app",
	"private": true,
	"packageManager": "bun@1.3.3",
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @my-better-t-app/backend dev",
		"dev:setup": "turbo -F @my-better-t-app/backend dev:setup"
	},
	"dependencies": {
		"@my-better-t-app/env": "workspace:*",
		"dotenv": "^17.2.2",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@my-better-t-app/config": "workspace:*",
		"@biomejs/biome": "^2.2.0",
		"turbo": "^2.6.3",
		"typescript": "^5"
	}
}
