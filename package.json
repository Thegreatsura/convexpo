{
	"name": "app",
	"private": true,
	"packageManager": "bun@1.3.3",
	"type": "module",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^5",
			"convex": "^1.32.0",
			"better-auth": "1.4.9",
			"@better-auth/expo": "1.4.9",
			"@convex-dev/better-auth": "^0.10.11"
		}
	},
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @app/backend dev",
		"dev:setup": "turbo -F @app/backend dev:setup"
	},
	"dependencies": {
		"@app/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@app/config": "workspace:*",
		"@biomejs/biome": "^2.2.0",
		"turbo": "^2.6.3",
		"typescript": "catalog:"
	}
}
